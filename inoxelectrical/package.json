{
  "name": "inox-electrical",
  "version": "1.0.0",
  "description": "Inox Electrical — single-page marketing site (SCSS + GSAP)",
  "private": true,
  "scripts": {
    "sass": "sass scss/main.scss css/style.css --style=expanded --source-map",
    "sass:build": "sass scss/main.scss css/style.css --style=compressed --no-source-map",
    "watch": "sass --watch scss/main.scss css/style.css --style=expanded"
  },
  "devDependencies": {
    "sass": "^1.101.0"
  }
}
